{
  "name": "sample-app-web",
  "homepage": "https://www.saucedemo.com",
  "version": "3.0.0",
  "private": true,
  "dependencies": {
    "@backtrace-labs/react": "^0.0.5",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "cheerio": "1.0.0-rc.3",
    "husky": "^9.1.7",
    "js-cookie": "^3.0.8",
    "react": "^19.2.7",
    "react-app-polyfill": "^2.0.0",
    "react-burger-menu": "^3.0.6",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^1.1.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/preset-env": "^7.29.7",
    "@babel/register": "^7.29.7",
    "@backtrace-labs/javascript-cli": "^0.1.2",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/preset-create-react-app": "^9.1.20",
    "@storybook/react-webpack5": "^9.1.20",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prop-types": "^15.7.2",
    "screener-storybook": "^0.21.2",
    "storybook": "^9.1.20",
    "wait-on": "^9.0.10"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "prepare": "husky",
    "test.coverage": "react-scripts test --coverage --watchAll=false",
    "test.coverage.watch": "react-scripts test --coverage --watchAll",
    "test.lint": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test.storybook.ci": "screener-storybook --conf test/visual/storybook/ci.config.js",
    "test.storybook.desktop": "screener-storybook --conf test/visual/storybook/desktop.config.js",
    "test.storybook.mobile": "screener-storybook --conf test/visual/storybook/mobile.config.js",
    "storybook": "storybook dev -p 6006",
    "build.storybook": "storybook build",
    "postbuild.storybook": "cd scripts && ./postbuild.sh",
    "backtrace.sourcemaps": "backtrace-js run"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "ie 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "ie 11"
    ]
  },
  "jest": {
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/jest.setupTextEncoder.js",
      "<rootDir>/src/setupTests.js",
      "<rootDir>/src/storybook/StoryRouter.js",
      "<rootDir>/src/utils/imageLoader.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.stories.{js,jsx,ts,tsx}",
      "!src/index.{js,jsx,ts,tsx}",
      "!src/service-worker.{js,jsx,ts,tsx}",
      "!src/serviceWorkerRegistration.{js,jsx,ts,tsx}",
      "!src/utils/withRouter.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "moduleNameMapper": {
      "\\.(jpg|png|svg)$": "<rootDir>/src/utils/__mocks__/fileMock.js"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
