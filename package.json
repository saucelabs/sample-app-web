{
  "name": "sample-app-web",
  "homepage": "https://www.saucedemo.com",
  "version": "3.0.0",
  "private": true,
  "engines": {
    "node": ">=24.9.0"
  },
  "dependencies": {
    "@backtrace/react": "^0.5.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "cheerio": "1.0.0-rc.3",
    "husky": "^9.1.7",
    "js-cookie": "^3.0.8",
    "react": "^19.2.7",
    "react-burger-menu": "^3.0.6",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-private-methods": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@backtrace/javascript-cli": "^0.3.2",
    "@saucelabs/visual-storybook": "^1.0.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-jest": "^30.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "prop-types": "^15.7.2",
    "storybook": "^10.4.6",
    "vite": "^8.1.3",
    "wait-on": "^9.0.10"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --watchAll=false",
    "prepare": "husky",
    "test.coverage": "jest --coverage --watchAll=false",
    "test.coverage.watch": "jest --coverage --watchAll",
    "test.lint": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "test.storybook": "npm run storybook -- --ci & npx wait-on --timeout 60000 http://localhost:6006 && test-storybook",
    "storybook": "storybook dev -p 6006",
    "build.storybook": "storybook build",
    "postbuild.storybook": "cd scripts && ./postbuild.sh",
    "backtrace.sourcemaps": "backtrace-js run"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
